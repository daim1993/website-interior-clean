NODE_ENV=production
PORT=4000
HOST=
TRUST_PROXY=1

# Public application URL used for Stripe redirect URLs.
APP_URL=https://your-domain.example

# Comma-separated browser origins allowed in production.
ORIGINS=https://your-domain.example

# Required in production. Use long random values.
SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-long-admin-password

# Optional Postgres persistence for hosts with ephemeral disks.
DATABASE_URL=

# Studio support address returned by /api/support and /api/plans.
SUPPORT_EMAIL=support@your-domain.example

# Stripe subscription billing.
STRIPE_SECRET=sk_live_replace_me
STRIPE_PRICE_PRO=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Optional notifications.
SLACK_WEBHOOK=

# Local snapshot backups.
BACKUP_DIR=./backups
BACKUP_KEEP=30
BACKUP_INTERVAL_MS=21600000
